{
  "manifest_version": 3,
  "name": "LyricPiP — Synced Lyrics & Picture-in-Picture",
  "version": "1.1.0",
  "description": "Karaoke-style synced lyrics for YouTube and Spotify Web, with an always-on-top Picture-in-Picture lyrics window. Powered by LRCLIB.",
  "minimum_chrome_version": "116",
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": ["https://lrclib.net/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "LyricPiP — Synced Lyrics",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["*://www.youtube.com/*", "*://m.youtube.com/*", "*://open.spotify.com/*"],
      "js": ["content/lrc-parser.js", "content/content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["*://www.youtube.com/*", "*://m.youtube.com/*", "*://open.spotify.com/*"],
      "js": ["content/main-world.js"],
      "world": "MAIN",
      "run_at": "document_idle"
    }
  ]
}
